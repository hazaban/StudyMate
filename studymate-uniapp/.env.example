# ============================================
# StudyMate 前端环境变量配置
# 部署到 Vercel 时，在 Environment Variables 里配置
# ============================================

# 后端 API 地址（部署时必填）
# 格式：https://你的后端域名/api
# 例如：https://studymate-api.onrender.com/api
VITE_API_BASE_URL=https://studymate-api.onrender.com/api
