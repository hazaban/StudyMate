# ============================================
# StudyMate 后端环境变量配置
# 部署到 Render 时，在 Environment Variables 里配置
# ============================================

# ---------- 数据库（必填）----------
# Supabase 推荐：Settings → Database → Connection string → URI
# 格式：postgresql://postgres:密码@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.xxx.supabase.co:5432/postgres

# ---------- JWT（必填）----------
# 生产环境务必改成随机字符串！
# 生成命令：openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- CORS（必填）----------
# 允许访问的前端域名，多个用逗号分隔
# 开发时用 *，生产环境建议填具体域名，如 https://studymate.vercel.app
CORS_ORIGINS=*

# ---------- 腾讯云 COS（图片存储，推荐配置）----------
# COS 控制台获取：https://console.cloud.tencent.com/cam/capi
COS_SECRET_ID=
COS_SECRET_KEY=
# 存储桶名称，如 studymate-1250000000
COS_BUCKET=
# 地域，如 ap-guangzhou / ap-shanghai / ap-beijing
COS_REGION=ap-guangzhou

# ---------- DeepSeek AI（可选，AI 生成功能用）----------
# https://platform.deepseek.com/api_keys 申请
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---------- 通义千问（可选，图片识别用）----------
# https://dashscope.console.aliyun.com/apiKey 申请
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_MODEL=qwen-vl-max
