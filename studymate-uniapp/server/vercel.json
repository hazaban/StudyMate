{
  "buildCommand": "echo 'No build needed for Python'",
  "outputDirectory": "public",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/api/index.py" }
  ]
}
